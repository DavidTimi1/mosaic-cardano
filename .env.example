# --- Database (Neo4j) ---
# Create a free AuraDB instance at https://console.neo4j.io
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# --- Caching & Locks (Redis) ---
# Create a free Redis instance at https://upstash.com
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Application Configuration ---
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPPORT_MAIL=
NEXT_PUBLIC_TREASURY_ADDRESS=
NEXT_PUBLIC_IS_LIVE=false

# --- Cardano Integrations ---
# Get your project ID from https://blockfrost.io/dashboard
BLOCKFROST_PROJECT_ID=

# --- Storage (Cloudinary) ---
# Get these from your Cloudinary Dashboard Settings -> Credentials
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- Decentralized Storage (Pinata / IPFS) ---
# Get your JWT from https://app.pinata.cloud/keys
PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=

# --- Email Services (Resend) ---
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
RESEND_TO_EMAIL=
RESEND_FROM_EMAIL=

# --- Wallet & Push Notifications ---
APP_WALLET_MNEMONIC=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=